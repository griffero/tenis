# Postgres connection string (Render will inject this automatically via render.yaml)
DATABASE_URL="postgresql://user:password@host:5432/tenis?schema=public"

# NextAuth
AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"
# On Render, set AUTH_TRUST_HOST=true (already configured in render.yaml)
AUTH_TRUST_HOST="true"

# Resend (https://resend.com/api-keys)
RESEND_API_KEY="re_your_api_key"
EMAIL_FROM="Tenis <no-reply@yourdomain.com>"
